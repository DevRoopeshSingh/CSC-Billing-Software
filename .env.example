# Environment Configuration

# Database
# For development: file:./dev.db (SQLite)
# For production: Electron sets USER_DATA_PATH automatically
DATABASE_URL="file:./dev.db"

# Optional: Production application data path
# This is automatically set by Electron when running as a packaged app
# USER_DATA_PATH will be set to: ~/Library/Application Support/CSC Billing/ (macOS)
# or %APPDATA%/CSC Billing/ (Windows)
