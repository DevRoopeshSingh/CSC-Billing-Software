# Environment Configuration

# Database
# Phase 1 web target: a Postgres URL (Neon, Supabase, RDS, or local docker).
#   Local docker:  postgres://postgres:postgres@localhost:5432/csc_billing
#   Neon (pooled): postgres://USER:PASS@HOST/db?sslmode=require
DATABASE_URL="postgres://postgres:postgres@localhost:5432/csc_billing"

# Legacy Electron / SQLite path (unused by the web slice). Kept while the
# desktop build still works in parallel.
# DATABASE_URL_SQLITE="file:./dev.db"

# ── Avnac Design Editor ───────────────────────────────────────────────────────
# Local dev: run `npm run dev` inside the avnac repo (defaults to port 3300).
# Production: set this to your deployed Avnac studio URL.
NEXT_PUBLIC_AVNAC_URL=http://localhost:3300
