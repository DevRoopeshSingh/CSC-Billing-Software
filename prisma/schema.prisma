// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model CenterProfile {
  id            Int     @id @default(autoincrement())
  centerName    String  @default("")
  address       String  @default("")
  mobile        String  @default("")
  email         String  @default("")
  udyamNumber   String  @default("")
  logoPath      String? // relative path under /uploads/
  upiQrPath     String? // relative path under /uploads/
  invoicePrefix       String    @default("INV-")
  invoiceNumber       Int       @default(0)
  theme               String    @default("light")
  defaultTaxRate      Float     @default(0)
  defaultPaymentMode  String    @default("Cash")
  lastBackupDate      DateTime?
  pinHash             String?
}

model Service {
  id           Int           @id @default(autoincrement())
  name         String
  category     String        @default("Other")
  defaultPrice Float         @default(0)
  taxRate      Float         @default(0)
  isActive     Boolean       @default(true)
  invoiceItems InvoiceItem[]
}

model Customer {
  id       Int       @id @default(autoincrement())
  name     String
  mobile   String    @default("")
  remarks  String?
  invoices Invoice[]
}

model Invoice {
  id          Int           @id @default(autoincrement())
  invoiceNo   String        @unique @default(uuid())
  createdAt   DateTime      @default(now())
  customer    Customer      @relation(fields: [customerId], references: [id])
  customerId  Int
  subtotal    Float
  taxTotal    Float         @default(0)
  discount    Float         @default(0)
  total       Float
  paymentMode   String        @default("Cash") // Cash | UPI | Other
  status        String        @default("PAID") // PAID | PENDING | CANCELLED
  notes         String?
  customerNotes String?
  items         InvoiceItem[]
}

model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  invoiceId   Int
  service     Service @relation(fields: [serviceId], references: [id])
  serviceId   Int
  description String
  qty         Int
  rate        Float
  taxRate     Float   @default(0)
  lineTotal   Float
}
