// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── Center Profile ──────────────────────────────────────────────────────────
model CenterProfile {
  id            Int     @id @default(autoincrement())
  centerName    String  @default("")
  address       String  @default("")
  mobile        String  @default("")
  email         String  @default("")
  udyamNumber   String  @default("")
  logoPath      String? // relative path under /uploads/
  upiQrPath     String? // relative path under /uploads/
  upiId          String? // UPI VPA for deep link generation
  invoicePrefix       String    @default("INV-")
  invoiceNumber       Int       @default(0)
  theme               String    @default("light")
  defaultTaxRate      Float     @default(0)
  defaultPaymentMode  String    @default("Cash")
  lastBackupDate      DateTime?
  pinHash             String?
  operatingHours      String    @default("")  // JSON: {"mon":"9:00-18:00",...,"sun":"Closed"}
  centerDescription   String    @default("")  // Brief text for agent context
}

// ─── Service ─────────────────────────────────────────────────────────────────
model Service {
  id           Int           @id @default(autoincrement())
  name         String
  category     String        @default("Other")
  defaultPrice Float         @default(0)
  taxRate      Float         @default(0)
  isActive     Boolean       @default(true)
  keywords     String        @default("")  // Aliases for fuzzy matching: "aadhaar,aadhar,uid"
  invoiceItems InvoiceItem[]
  checklists   ServiceChecklist[]
}

// ─── Customer ────────────────────────────────────────────────────────────────
model Customer {
  id       Int       @id @default(autoincrement())
  name     String
  mobile   String    @default("")
  remarks  String?
  email    String    @default("")
  address  String    @default("")
  tags     String    @default("")  // Comma-separated: "VIP,Frequent,Govt"
  invoices Invoice[]
}

// ─── Invoice ─────────────────────────────────────────────────────────────────
model Invoice {
  id          Int           @id @default(autoincrement())
  invoiceNo   String        @unique @default(uuid())
  createdAt   DateTime      @default(now())
  customer    Customer      @relation(fields: [customerId], references: [id])
  customerId  Int
  subtotal    Float
  taxTotal    Float         @default(0)
  discount    Float         @default(0)
  total       Float
  paymentMode   String        @default("Cash") // Cash | UPI | Other
  status        String        @default("PAID") // PAID | PENDING | CANCELLED
  notes         String?
  customerNotes String?
  printedAt     DateTime?
  items         InvoiceItem[]
}

// ─── Invoice Item ────────────────────────────────────────────────────────────
model InvoiceItem {
  id          Int     @id @default(autoincrement())
  invoice     Invoice @relation(fields: [invoiceId], references: [id])
  invoiceId   Int
  service     Service @relation(fields: [serviceId], references: [id])
  serviceId   Int
  description String
  qty         Int
  rate        Float
  taxRate     Float   @default(0)
  lineTotal   Float
}

// ═══════════════════════════════════════════════════════════════════════════════
// AGENT-READY MODELS (Phase 1)
// ═══════════════════════════════════════════════════════════════════════════════

// ─── FAQ / Knowledge Base ────────────────────────────────────────────────────
model FaqEntry {
  id          Int      @id @default(autoincrement())
  question    String
  answer      String
  category    String   @default("General")
  tags        String   @default("")
  isPublished Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Service Document Checklists ─────────────────────────────────────────────
model ServiceChecklist {
  id           Int     @id @default(autoincrement())
  service      Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  serviceId    Int
  documentName String
  isRequired   Boolean @default(true)
  notes        String  @default("")
  sortOrder    Int     @default(0)
}

// ─── Lead Capture ────────────────────────────────────────────────────────────
model Lead {
  id              Int      @id @default(autoincrement())
  name            String
  mobile          String   @default("")
  email           String   @default("")
  serviceInterest String   @default("")
  source          String   @default("manual")
  status          String   @default("NEW")
  notes           String?
  createdAt       DateTime @default(now())
  convertedCustomerId Int?
}

// ─── Message Templates ──────────────────────────────────────────────────────
model MessageTemplate {
  id       Int     @id @default(autoincrement())
  name     String
  channel  String  @default("whatsapp")
  body     String
  isActive Boolean @default(true)
}

// ─── Agent Interaction Log ──────────────────────────────────────────────────
model AgentLog {
  id            Int      @id @default(autoincrement())
  agentType     String
  sessionId     String   @default("")
  role          String
  content       String
  toolName      String   @default("")
  toolInput     String   @default("")
  durationMs    Int      @default(0)
  createdAt     DateTime @default(now())
}

// ─── API Keys for Agent Auth ────────────────────────────────────────────────
model ApiKey {
  id         Int       @id @default(autoincrement())
  key        String    @unique
  name       String
  scope      String    @default("copilot")
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
}
