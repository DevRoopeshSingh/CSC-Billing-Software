{
  "name": "csc-center-billing-software",
  "version": "0.1.0",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "db:push:drizzle": "drizzle-kit push",
    "db:generate:drizzle": "drizzle-kit generate",
    "electron:compile": "node scripts/build-electron.mjs",
    "seed:admin": "ELECTRON_RUN_AS_NODE=1 electron scripts/seed-admin.mjs",
    "electron:dev": "npm run electron:compile && npm run rebuild:electron && concurrently -k \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "npm run electron:compile && npm run rebuild:electron && npm run build && electron-builder build --mac --win",
    "rebuild:electron": "electron-rebuild -f -w node-thermal-printer,better-sqlite3"
  },
  "build": {
    "appId": "com.csc.billing",
    "productName": "CSC Billing",
    "asar": true,
    "asarUnpack": [
      "**/node_modules/better-sqlite3/**/*",
      "**/node_modules/node-thermal-printer/**/*"
    ],
    "directories": {
      "output": "dist_electron",
      "buildResources": "build"
    },
    "files": [
      ".next/standalone/**/*",
      {
        "from": ".next/static",
        "to": ".next/standalone/.next/static"
      },
      {
        "from": "public",
        "to": ".next/standalone/public"
      },
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/seeds",
        "to": "seeds",
        "filter": [
          "**/*"
        ]
      }
    ],
    "afterPack": "scripts/after-pack.mjs",
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    }
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.36.4",
    "electron-updater": "^6.8.3",
    "lucide-react": "^0.460.0",
    "next": "^16.1.7",
    "node-thermal-printer": "^4.6.0",
    "pdf-lib": "^1.17.1",
    "react": "^18",
    "react-dom": "^18",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@eslint/js": "^9.17.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.28.1",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "esbuild": "^0.24.0",
    "eslint": "^10",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "playwright": "^1.59.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "typescript-eslint": "^8.18.0",
    "uuid": "^13.0.0",
    "wait-on": "^9.0.4"
  }
}
