# ── Dependencies ─────────────────────────────────────────────────────────────
node_modules/

# ── Next.js build output ────────────────────────────────────────────────────
.next/
out/

# ── TypeScript build cache ──────────────────────────────────────────────────
tsconfig.tsbuildinfo
*.tsbuildinfo

# ── Next.js auto-generated types ────────────────────────────────────────────
next-env.d.ts

# ── Environment / secrets ───────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── SQLite database (local dev data) ────────────────────────────────────────
*.db
*.db-journal
*.db-wal

# ── Electron packaging output ───────────────────────────────────────────────
dist/
dist-electron/
release/

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── OS-specific junk ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
ehthumbs.db

# ── IDE / Editor settings ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ── User uploads (local runtime data, not source) ──────────────────────────
public/uploads/*
!public/uploads/README.md

# ── Backups (generated at runtime) ──────────────────────────────────────────
backups/
*.backup
*.bak

# ── Testing / Coverage ─────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Misc ────────────────────────────────────────────────────────────────────
.vercel
.turbo
.claude/

# ── Electron build artifacts ───────────────────────────────────────────
dist-electron/
dist_electron/

# ── Native module build ──────────────────────────────────────────────────
.gyp.json
